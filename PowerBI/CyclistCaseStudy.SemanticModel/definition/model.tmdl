model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

queryGroup 'Transform File from DATAfile_Consolidated'

	annotation PBI_QueryGroupOrder = 0

queryGroup 'Transform File from DATAfile_Consolidated\Helper Queries'

	annotation PBI_QueryGroupOrder = 0

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["Trips","Sample File","Parameter1","Transform Sample File","Transform File","Measures Table"]

annotation PBI_ProTooling = ["DevMode"]

ref table Trips
ref table Date
ref table 'Measures Table'

ref cultureInfo en-US

