table 'Measures Folder'
	lineageTag: bb07b7fc-739d-4025-ad63-44a53bc3ddf7

	measure 'Total Rides' = COUNTROWS(Trips)  --Counts all rows in the Trips table. Relies on upstream cleaning for invalid record removal.
		formatString: #,0
		displayFolder: Core
		lineageTag: 35679c21-9640-493e-b0ec-cda29b2a7a85

	measure 'Member Rides' =
			-- Filters to member rides only.
			CALCULATE(
			    COUNTROWS(Trips),
			    Trips[member_casual] = "member"
			)
		formatString: #,0
		displayFolder: Core
		lineageTag: 6db79f1f-c0f5-4f4d-b5a8-1233b46f9ad1

	measure 'Casual Rides' =
			-- Filters to casual rides only.
			CALCULATE(
			    COUNTROWS(Trips),
			    Trips[member_casual] = "casual"
			)
		formatString: #,0
		displayFolder: Core
		lineageTag: be6be4fd-a920-4032-b7fb-33a31ceb4691

	measure 'Member Ride %' =
			-- Returns the proportion of rides by members. BLANK() returned on divide-by-zero to stay consistent with null-handling convention.
			DIVIDE([Member Rides], [Total Rides], BLANK())
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Core
		lineageTag: 11101433-6c0f-461a-a7c7-f3c2f40514c9

	measure 'Avg Ride Duration (min)' =
			
			AVERAGEX(
			    FILTER(Trips, Trips[Ride Time (min)] > 0),
			    Trips[Ride Time (min)]
			)
			/*
			Averages decimal-minute ride durations. Filters out zero and blank values before averaging to avoid skewing the result.*/
		displayFolder: Core
		lineageTag: a2c0b2c2-3ef3-4e0b-8a20-d586c7707342

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Avg Ride Distance (mi)' =
			
			/*Averages Haversine-calculated ride distances in miles. Same filter logic as duration.*/
			AVERAGEX(
			    FILTER(Trips, Trips[Ride Distance (mi)] > 0),
			    Trips[Ride Distance (mi)]
			)
		displayFolder: Core
		lineageTag: d1c15fe3-3deb-4e5d-952f-8063ec3bbdbc

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Weekday Rides' = ```
			
			/*// Counts rides occurring on weekdays (Monday–Friday). Uses the Is Weekend column from the Date Table.*/
			CALCULATE([Total Rides], 'Date'[Is Weekend] = FALSE())
			
			
			```
		formatString: 0
		displayFolder: Temporal
		lineageTag: 39229bc2-e586-45ca-b573-b5e9184b63e1

	measure 'Weekend Rides' = ```
			
			/*Counts rides occurring on weekends (Saturday–Sunday).  */
			CALCULATE([Total Rides], 'Date'[Is Weekend] = TRUE())
			
			
			```
		formatString: 0
		displayFolder: Temporal
		lineageTag: 385add80-90d1-4541-a0f0-0092edc72052

	measure 'Weekend Ride %' = ```
			
			DIVIDE([Weekend Rides], [Total Rides], BLANK())
			/* 
			Proportion of all rides occurring on weekends. BLANK() returned on divide-by-zero consistent with null-handling convention. */
			```
		displayFolder: Temporal
		lineageTag: 89b49b6e-2e73-4d4d-b054-fef8a43cad66

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Avg Duration Casual' = ```
			
			AVERAGEX(
			    FILTER(Trips, Trips[member_casual] = "casual" && Trips[Ride Time (min)] > 0),
			    Trips[Ride Time (min)]
			)
			/* 
			Average ride duration in decimal minutes for casual riders only. Same filter logic as member duration. */
			```
		displayFolder: Temporal
		lineageTag: 7e4ff32d-3ee1-42c8-adc3-8bbadc810dfc

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Avg Duration Member' = ```
			
			AVERAGEX(
			    FILTER(Trips, Trips[member_casual] = "member" && Trips[Ride Time (min)] > 0),
			    Trips[Ride Time (min)]
			)
			/* 
			Average ride duration in decimal minutes for members only. Filters out zero and blank values before averaging. */
			```
		displayFolder: Temporal
		lineageTag: 9aa5b069-a6d5-482e-b577-c6871963aecc

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Spring Rides' =
			
			CALCULATE([Total Rides], 'Date'[Season] = "Spring")
		formatString: 0
