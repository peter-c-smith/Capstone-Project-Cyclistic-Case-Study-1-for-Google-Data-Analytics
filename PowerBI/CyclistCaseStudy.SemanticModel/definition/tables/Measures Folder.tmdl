	measure 'Member % by Metric' =
			
			SWITCH(
			    SELECTEDVALUE('Metric Groups'[Metric]),
			    "Weekend %", [Member Weekend %],
			    "Round Trip %", [Round Trip % Member],
			    BLANK()
			)
			/* Returns the appropriate member percentage measure based on the selected metric category from the Metric Groups table. Used as a Y-axis series in the Page 2 clustered column chart. Set color to #1F77B4 in the visual format pane. */
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Behavioral Ratios
		lineageTag: 3421be5d-e7f7-4dd4-b030-91bf5d6fefd7

	measure 'Casual % by Metric' = ```
			
			SWITCH(
			    SELECTEDVALUE('Metric Groups'[Metric]),
			    "Weekend %", [Casual Weekend %],
			    "Round Trip %", [Round Trip % Casual],
			    BLANK()
			)
			/* 
			Returns the appropriate casual percentage measure based on the selected metric category from the Metric Groups table. Used as a Y-axis series in the Page 2 clustered column chart. Set color to #FF7F0E in the visual format pane. */
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Behavioral Ratios
		lineageTag: 4e67ee63-c34e-452d-8436-4b30165c78df

	measure 'Annotation Page 2 Pace Insight' =
			
			VAR DurationRatio = [Duration Ratio Casual to Member]
			VAR DistanceRatio = [Distance Ratio Casual to Member]
			VAR DurationPct = FORMAT((DurationRatio - 1) * 100, "0")
			VAR DistancePct = FORMAT(ABS(DistanceRatio - 1) * 100, "0")
			VAR DistanceDirection = IF(DistanceRatio >= 1, "more", "less")
			RETURN
			    "Casual riders take " & DurationPct & "% longer rides but cover only " & DistancePct & "% " & DistanceDirection & " distance than members. This suggests casual riders move at a more leisurely pace — prioritizing the experience of riding over reaching a destination efficiently."
		displayFolder: Annotations
		lineageTag: cddb6663-e08b-41a5-8be6-92ff5b79da4e

	measure 'Annotation Duration Card Callout' = ```
			
			VAR DurationRatio = [Duration Ratio Casual to Member]
			VAR DurationPct = FORMAT((DurationRatio - 1) * 100, "0")
			RETURN
			    "Casual riders average " & DurationPct & "% longer rides than members"
			/* 
			Dynamic text callout displayed beneath the duration card pair on Page 2. Updates automatically when slicers are adjusted.
			 */
			```
		displayFolder: Annotations
		lineageTag: 73577803-7433-4f1e-a5b6-38536db0fb47

	measure 'Annotation Distance Card Callout' = ```
			
			VAR DistanceRatio = [Distance Ratio Casual to Member]
			VAR DistancePct = FORMAT((DistanceRatio - 1) * 100, "0")
			RETURN
			    IF(
			        DistanceRatio >= 1,
			        "Casual riders cover " & DistancePct & "% more distance per ride than members",
			        "Casual riders cover " & FORMAT((1 - DistanceRatio) * 100, "0") & "% less distance per ride than members"
			    )
			/* 
			Dynamic text callout displayed beneath the distance card pair on Page 2. Handles both directions — if casual riders cover more distance it says "more", if less it says "less". Updates automatically when slicers are adjusted. */
			```
		displayFolder: Annotations
		lineageTag: 0300ed63-7254-4f84-8df6-d7daad5f0401

	measure 'Member Rides by Day Type' = ```
			
			SWITCH(
			    SELECTEDVALUE('Day Type Groups'[Day Type]),
			    "Weekday", CALCULATE([Member Rides], 'Date'[Is Weekend] = FALSE()),
			    "Weekend", CALCULATE([Member Rides], 'Date'[Is Weekend] = TRUE()),
			    BLANK()
			)
			/* 
			Returns member ride count for the selected day type category from the Day Type Groups table. Used as a Y-axis series in the Page 3 Weekday vs Weekend clustered column chart. */
			```
		formatString: 0
		displayFolder: Temporal
		lineageTag: dc759f39-51d3-46c0-8eb1-e21330f79f1d

	measure 'Casual Rides by Day Type' = ```
			
			SWITCH(
			    SELECTEDVALUE('Day Type Groups'[Day Type]),
			    "Weekday", CALCULATE([Casual Rides], 'Date'[Is Weekend] = FALSE()),
			    "Weekend", CALCULATE([Casual Rides], 'Date'[Is Weekend] = TRUE()),
			    BLANK()
			)
			/* 
			Returns casual ride count for the selected day type category from the Day Type Groups table. Used as a Y-axis series in the Page 3 Weekday vs Weekend clustered column chart */
			```
		formatString: 0
		displayFolder: Temporal
		lineageTag: 3c5e4e47-13e5-4eff-bce2-822e41427762

	measure 'Annotation Page 3 Temporal Insight' =
			
			VAR SummerCasual = [Summer Rides] - CALCULATE([Summer Rides], Trips[member_casual] = "member")
			VAR TotalCasual = [Casual Rides]
			VAR SummerCasualPct = FORMAT(DIVIDE(SummerCasual, TotalCasual) * 100, "0")
			RETURN
			    "Members spike at commuter hours and favor weekdays year-round. Casual riders peak midday and on weekends — with " & SummerCasualPct & "% of all casual rides occurring in summer months."
		displayFolder: Annotations
		lineageTag: d85a3556-f97f-4349-a95f-0732c283e2b9

	partition 'Measures Folder' = m
		mode: import
		source =
				let
				    Source = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText("i44FAA==", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [Column1 = _t]),
				    #"Changed Type" = Table.TransformColumnTypes(Source,{{"Column1", type text}}),
				    #"Removed Columns" = Table.RemoveColumns(#"Changed Type",{"Column1"})
				in
				    #"Removed Columns"

	changedProperty = Name

	annotation PBI_ResultType = Table

