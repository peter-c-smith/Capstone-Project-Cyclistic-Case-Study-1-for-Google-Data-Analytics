    <DTS:Executable
      DTS:refId="Package\Transform stg to dbo_Trips"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{83551AAD-76DE-4B4F-86A5-B5569CC4C402}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Transform stg to dbo_Trips"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{1CF096C4-3ADC-4B9F-956D-0D03CC0E67EB}"
          SQLTask:SqlStatementSource="INSERT INTO dbo.Trips (&#xA;    ride_id, rideable_type, started_at, ended_at,&#xA;    start_station_name, start_station_id,&#xA;    end_station_name, end_station_id,&#xA;    start_lat, start_lng, end_lat, end_lng,&#xA;    member_casual, ride_time_min, ride_distance_mi, source_file&#xA;)&#xA;SELECT&#xA;    ride_id,&#xA;    rideable_type,&#xA;    TRY_CAST(started_at AS DATETIME2),&#xA;    TRY_CAST(ended_at AS DATETIME2),&#xA;    NULLIF(LTRIM(RTRIM(start_station_name)), ''),&#xA;    NULLIF(LTRIM(RTRIM(start_station_id)), ''),&#xA;    NULLIF(LTRIM(RTRIM(end_station_name)), ''),&#xA;    NULLIF(LTRIM(RTRIM(end_station_id)), ''),&#xA;    TRY_CAST(start_lat AS DECIMAL(10,6)),&#xA;    TRY_CAST(start_lng AS DECIMAL(10,6)),&#xA;    TRY_CAST(end_lat AS DECIMAL(10,6)),&#xA;    TRY_CAST(end_lng AS DECIMAL(10,6)),&#xA;    member_casual,&#xA;    CASE&#xA;        WHEN TRY_CAST(started_at AS DATETIME2) IS NULL&#xA;          OR TRY_CAST(ended_at AS DATETIME2) IS NULL THEN NULL&#xA;        WHEN DATEDIFF(SECOND,&#xA;                TRY_CAST(started_at AS DATETIME2),&#xA;                TRY_CAST(ended_at AS DATETIME2)) &lt; 0 THEN NULL&#xA;        ELSE CAST(DATEDIFF(SECOND,&#xA;                TRY_CAST(started_at AS DATETIME2),&#xA;                TRY_CAST(ended_at AS DATETIME2))&#xA;             AS DECIMAL(10,4)) / 60&#xA;    END,&#xA;    CASE&#xA;        WHEN TRY_CAST(start_lat AS FLOAT) IS NULL&#xA;          OR TRY_CAST(start_lng AS FLOAT) IS NULL&#xA;          OR TRY_CAST(end_lat AS FLOAT) IS NULL&#xA;          OR TRY_CAST(end_lng AS FLOAT) IS NULL THEN NULL&#xA;        ELSE 3958.8 * 2.0 * ASIN(SQRT(&#xA;            POWER(SIN((RADIANS(TRY_CAST(end_lat AS FLOAT))&#xA;                - RADIANS(TRY_CAST(start_lat AS FLOAT))) / 2.0), 2) +&#xA;            COS(RADIANS(TRY_CAST(start_lat AS FLOAT))) *&#xA;            COS(RADIANS(TRY_CAST(end_lat AS FLOAT))) *&#xA;            POWER(SIN((RADIANS(TRY_CAST(end_lng AS FLOAT))&#xA;                - RADIANS(TRY_CAST(start_lng AS FLOAT))) / 2.0), 2)&#xA;        ))&#xA;    END,&#xA;    source_file&#xA;FROM stg.Trips&#xA;WHERE ride_id IS NOT NULL&#xA;  AND rideable_type IS NOT NULL&#xA;  AND TRY_CAST(started_at AS DATETIME2) IS NOT NULL&#xA;  AND TRY_CAST(ended_at AS DATETIME2) IS NOT NULL&#xA;  AND member_casual IS NOT NULL;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
